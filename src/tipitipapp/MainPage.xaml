<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:tipitipapp.Behaviors"
             xmlns:viewModels="clr-namespace:tipitipapp.ViewModels"
             x:Class="tipitipapp.MainPage"
             Title="TipIt"
             BackgroundColor="{StaticResource PrimaryBackgroundColor}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with Logout -->
        <Grid Grid.Row="0" 
              Padding="20,40,20,20"
              BackgroundColor="{StaticResource PrimaryColor}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   Text="TipIt"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center" />

            <Button Grid.Column="1"
                    Text="LogOut"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="16"
                    BorderColor="White"
                    BorderWidth="1"
                    CornerRadius="20"
                    Padding="15,8"
                    WidthRequest="80" />
        </Grid>

        <!-- Main Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="30" 
                                 Padding="20"
                                 VerticalOptions="Center">

                <!-- Logo Section -->
                <VerticalStackLayout Spacing="10" 
                                     HorizontalOptions="Center">
                    <Image Source="logo.png"
                           WidthRequest="120"
                           HeightRequest="120"
                           Aspect="AspectFit" />
                    <Label Text="Welcome to TipIt"
                           FontSize="18"
                           TextColor="Gray"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Amount Input Section -->
                <VerticalStackLayout Spacing="15">
                    <Label Text="Amount"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryColor}" />

                    <Frame BorderColor="LightGray"
                           CornerRadius="10"
                           Padding="0"
                           BackgroundColor="White"
                           HeightRequest="60">
                        <Entry x:Name="AmountEntry"
                               Text="{Binding Amount}"
                               Placeholder="Enter amount"
                               Keyboard="Numeric"
                               FontSize="24"
                               TextColor="{StaticResource PrimaryColor}"
                               HorizontalTextAlignment="Center"
                               VerticalOptions="Center"
                               ReturnType="Done">
                            <Entry.Behaviors>
                                <behaviors:EventToCommandBehavior 
                                    EventName="TextChanged" 
                                    Command="{Binding AmountChangedCommand}" />
                            </Entry.Behaviors>
                        </Entry>
                    </Frame>
                </VerticalStackLayout>

                <!-- Quick Tip Amounts -->
                <VerticalStackLayout Spacing="15">
                    <Label Text="Quick Tip Amounts"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryColor}" />

                    <HorizontalStackLayout Spacing="15" 
                                           HorizontalOptions="Center">

                        <!-- $5 Button -->
                        <Button Text="$5"
                                Command="{Binding QuickTipCommand}"
                                CommandParameter="5"
                                BackgroundColor="{StaticResource SecondaryColor}"
                                TextColor="White"
                                FontSize="18"
                                FontAttributes="Bold"
                                CornerRadius="25"
                                WidthRequest="80"
                                HeightRequest="80" />

                        <!-- $10 Button -->
                        <Button Text="$10"
                                Command="{Binding QuickTipCommand}"
                                CommandParameter="10"
                                BackgroundColor="{StaticResource SecondaryColor}"
                                TextColor="White"
                                FontSize="18"
                                FontAttributes="Bold"
                                CornerRadius="25"
                                WidthRequest="80"
                                HeightRequest="80" />

                        <!-- $15 Button -->
                        <Button Text="$15"
                                Command="{Binding QuickTipCommand}"
                                CommandParameter="15"
                                BackgroundColor="{StaticResource SecondaryColor}"
                                TextColor="White"
                                FontSize="18"
                                FontAttributes="Bold"
                                CornerRadius="25"
                                WidthRequest="80"
                                HeightRequest="80" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Collect Tip Section -->
                <VerticalStackLayout Spacing="15">
                    <Label Text="Collect Tip"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryColor}" />

                    <Button Text="Collect Tip"
                            Command="{Binding CollectTipCommand}"
                            BackgroundColor="{StaticResource PrimaryColor}"
                            TextColor="White"
                            FontSize="20"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="60" />
                </VerticalStackLayout>

                <!-- Current Tip Display -->
                <Frame BorderColor="LightGray"
                       CornerRadius="10"
                       Padding="20"
                       BackgroundColor="#F5F5F5"
                       IsVisible="{Binding HasTipAmount}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Current Tip"
                               FontSize="14"
                               TextColor="Gray"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding CurrentTipAmount, StringFormat='${0:F2}'}"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="{StaticResource SuccessColor}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading Overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              IsVisible="{Binding IsProcessing}"
              BackgroundColor="#80000000"
              InputTransparent="False">
            <VerticalStackLayout HorizontalOptions="Center" 
                                 VerticalOptions="Center"
                                 Spacing="20">
                <ActivityIndicator IsRunning="{Binding IsProcessing}"
                                   Color="{StaticResource PrimaryColor}"
                                   WidthRequest="50"
                                   HeightRequest="50" />
                <Label Text="{Binding ProcessingMessage}"
                       TextColor="White"
                       FontSize="16"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>